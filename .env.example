# Bu dosya repoya GİRER — yalnızca placeholder, gerçek anahtar KOYMAYIN.
# Kurulum: bu dosyayı `.env.local` olarak kopyalayın ve değerleri doldurun.

# --- CLIENT (tarayıcıya gömülür, anon key güvenli + RLS korur) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

